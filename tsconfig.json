{
    "compilerOptions":  {
                            "target":  "ES2020",
                            "useDefineForClassFields":  true,
                            "lib":  [
                                        "ES2020",
                                        "DOM",
                                        "DOM.Iterable"
                                    ],
                            "module":  "ESNext",
                            "skipLibCheck":  true,
                            "esModuleInterop":  true,
                            "allowSyntheticDefaultImports":  true,
                            "moduleResolution":  "bundler",
                            "allowImportingTsExtensions":  true,
                            "resolveJsonModule":  true,
                            "isolatedModules":  true,
                            "noEmit":  true,
                            "jsx":  "react-jsx",
                            "strict":  true,
                            "noUnusedLocals":  true,
                            "noUnusedParameters":  true,
                            "noFallthroughCasesInSwitch":  true,
                            "baseUrl":  ".",
                            "paths":  {
                                          "@/*":  [
                                                      "./src/*"
                                                  ],
                                          "@components/*":  [
                                                                "./src/components/*"
                                                            ],
                                          "@pages/*":  [
                                                           "./src/pages/*"
                                                       ],
                                          "@types/*":  [
                                                           "./src/types/*"
                                                       ],
                                          "@utils/*":  [
                                                           "./src/utils/*"
                                                       ],
                                          "@assets/*":  [
                                                            "./src/assets/*"
                                                        ]
                                      }
                        },
    "include":  [
                    "src"
                ],
    "exclude":  [
                    "node_modules",
                    "dist",
                    "build",
                    "docs",
                    "**/backups/**",
                    "**/*.backup.*",
                    "**/__test__/**",
                    "**/*.backup-*",
                    "**/pages_backup/**",
                    "**/complete_backups/**",
                    "**/source_backups/**",
                    "**/medical-platform-ts-fix-backup*/**"
                ]
}

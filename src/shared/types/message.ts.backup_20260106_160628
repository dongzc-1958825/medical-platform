  'id' | 'createdAt' | 'status' | 'version' | 
  'viewCount' | 'likeCount' | 'commentCount' | 'shareCount' | 'saveCount' |
  'isFeatured' | 'isVerified' | 'storageTier' | 'estimatedValueScore' |
  'lastAccessedAt' | 'relatedPostIds' | 'metadata'
>;


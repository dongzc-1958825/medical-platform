/**
 * 数据价值评估指标
 */
export interface ValueMetrics {
  // 互动指标
  viewCount: number;
  likeCount: number;
  commentCount: number;
  shareCount: number;
  saveCount: number;
  
  // 质量指标
  isFeatured: boolean;
  isVerified: boolean;
  hasAuthorCredentials: boolean;
  
  // 计算综合价值分数（0-100）
  calculateScore(): number {
    const weights = {
      views: 0.15,    // 15%
      likes: 0.25,    // 25%
      comments: 0.20, // 20%
      shares: 0.15,   // 15%
      saves: 0.10,    // 10%
      featured: 0.08, // 8%
      verified: 0.05, // 5%
      credentials: 0.02 // 2%
    };
    
    let score = 0;
    
    // 互动分数（归一化处理）
    const maxViews = 1000;
    const maxLikes = 500;
    const maxComments = 200;
    const maxShares = 300;
    const maxSaves = 100;
    
    score += (Math.min(this.viewCount, maxViews) / maxViews) * 100 * weights.views;
    score += (Math.min(this.likeCount, maxLikes) / maxLikes) * 100 * weights.likes;
    score += (Math.min(this.commentCount, maxComments) / maxComments) * 100 * weights.comments;
    score += (Math.min(this.shareCount, maxShares) / maxShares) * 100 * weights.shares;
    score += (Math.min(this.saveCount, maxSaves) / maxSaves) * 100 * weights.saves;
    
    // 质量分数
    if (this.isFeatured) score += 100 * weights.featured;
    if (this.isVerified) score += 100 * weights.verified;
    if (this.hasAuthorCredentials) score += 100 * weights.credentials;
    
    return Math.min(Math.round(score), 100);
  }
}

// ==================== 微信互通类型 ====================

/**
 * 微信内容导入选项
 */
export interface WeChatImportOptions {
  autoDetectCategory: boolean;
  extractTags: boolean;
  generateSummary: boolean;
  preserveOriginal: boolean;
  optimizeForSharing: boolean;
}

/**
 * 微信分享模板
 */
export interface WeChatShareTemplate {
  titleTemplate: string;
  contentTemplate: string;
  footerTemplate: string;
  maxLength: number;
  
  generate(post: MedicalPost): string {
    // 内容预览（截取前100字符）
    const contentPreview = post.content.length > 100 
      ? post.content.substring(0, 100) + '...' 
      : post.content;
    
    // 构建分享内容
    return `${this.titleTemplate.replace('{title}', post.title)}

${contentPreview}

${this.footerTemplate}
—— 分享自医案平台
作者：${post.authorName}${post.authorCredentials ? ` (${post.authorCredentials})` : ''}
${post.institution ? `机构：${post.institution}` : ''}`;
  }
}

// ==================== 工具函数和类型守卫 ====================

/**
 * 类型守卫：检查是否为消息帖子
 */
export function isMessagePost(post: MedicalPost): post is MessagePost {
  return post.entityType === 'message';
}

/**
 * 类型守卫：检查是否为医案帖子
 */
export function isMedicalCasePost(post: MedicalPost): post is MedicalCasePost {
  return post.entityType === 'case';
}

/**
 * 类型守卫：检查是否为咨询帖子
 */
export function isConsultationPost(post: MedicalPost): post is ConsultationPost {
  return post.entityType === 'consultation';
}


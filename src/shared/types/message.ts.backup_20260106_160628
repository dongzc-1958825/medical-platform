// ==================== 导出所有类型 ====================

/**
 * 医疗数据模型工具集
 */
export const MedicalDataUtils = {
  getCategoryDisplayName,
  getRoleDisplayName,
  getStatusDisplayName,
  isMessagePost,
  isMedicalCasePost,
  isConsultationPost,
  
  /**
   * 创建默认的医疗帖子
   */
  createDefaultPost(authorInfo: {
    id: string;
    name: string;
    role: AuthorRole;
  }): Omit<MedicalPost, 'id' | 'createdAt'> {
    return {
      entityType: 'message',
      title: '',
      content: '',
      tags: [],
      keywords: [],
      authorId: authorInfo.id,
      authorName: authorInfo.name,
      authorRole: authorInfo.role,
      status: 'active',
      version: 1,
      viewCount: 0,
      likeCount: 0,
      commentCount: 0,
      shareCount: 0,
      saveCount: 0,
      isFeatured: false,
      isVerified: false,
      storageTier: 'hot',
      estimatedValueScore: 50,
      relatedPostIds: [],
      metadata: {}
    };
  },
  
  /**
   * 从微信内容创建导入数据
   */
  createFromWeChatContent(
    wechatContent: string,
    authorInfo: { id: string; name: string; role: AuthorRole },
    category?: MessageCategory
  ): CreatePostData {
    // 自动提取标题（第一行或前50字符）
    const firstLine = wechatContent.split('\n')[0];
    const title = firstLine.length > 50 ? firstLine.substring(0, 50) + '...' : firstLine;
    
    // 自动提取关键词（简单实现）
    const medicalKeywords = ['治疗', '药物', '病例', '医院', '医生', '患者', '疗效', '副作用'];
    const foundKeywords = medicalKeywords.filter(keyword => 
      wechatContent.includes(keyword)
    );
    
    return {
      entityType: 'message',
      title: title || '微信分享内容',
      content: wechatContent,
      summary: wechatContent.length > 100 ? wechatContent.substring(0, 100) + '...' : wechatContent,
      category,
      tags: foundKeywords,
      keywords: foundKeywords,
      authorId: authorInfo.id,
      authorName: authorInfo.name,
      authorRole: authorInfo.role,
      sourceType: 'wechat',
      originalWeChatContent: wechatContent,
      medicalField: undefined,
      evidenceLevel: undefined,
      patientInfo: undefined,
      treatmentOutcome: undefined
    };
  }
};
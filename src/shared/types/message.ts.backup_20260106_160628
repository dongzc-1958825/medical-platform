/**
 * 医疗数据模型定义 - 为五大功能提供统一数据基础
 * 设计原则：长期存储、医疗行业特点、微信互通友好
 * 位置：src/shared/types/ - 符合统一数据统一业务逻辑原则
 */

// ==================== 核心类型定义 ====================

/**
 * 消息分类 - 五大专业分类（用于消息功能）
 */
export type MessageCategory = 
  | 'new-drug'           // 新药信息：药品研发、临床试验、用药经验
  | 'professional-article' // 专业文章：医学论文、研究成果、学术观点
  | 'announcement'       // 公告发布：平台通知、会议信息、政策解读
  | 'special-effect'     // 特效分享：特效方案、成功案例、独特疗法
  | 'lesson-learned';    // 前车之鉴：经验教训、诊疗误区、风险警示

/**
 * 数据状态 - 反映数据生命周期
 */
export type DataStatus = 
  | 'active'       // 活跃：正常可访问
  | 'withdrawn'    // 已撤回：作者主动撤回
  | 'corrected'    // 已修正：内容有更新
  | 'archived'     // 已归档：不活跃但长期保存
  | 'deprecated';  // 已弃用：信息过时但仍保留参考

/**
 * 作者角色 - 医疗行业特定角色
 */
export type AuthorRole = 
  | 'doctor'           // 医生
  | 'patient'          // 患者
  | 'researcher'       // 研究人员
  | 'pharmacist'       // 药师
  | 'nurse'           // 护士
  | 'administrator'   // 管理人员
  | 'medical-student' // 医学生
  | 'other';          // 其他

/**
 * 存储层级 - 基于访问频率和价值的分级存储
 */
export type StorageTier = 
  | 'hot'      // 热数据：频繁访问，高性能存储
  | 'warm'     // 温数据：偶尔访问，标准存储
  | 'cold'     // 冷数据：很少访问，低成本存储
  | 'archive'; // 归档数据：几乎不访问，长期保存

// ==================== 统一数据模型 ====================

/**
 * 医疗数据帖子 - 统一数据模型（为五大功能设计）
 * 核心原则：长期存储、可追溯、微信互通友好
 */
export interface MedicalPost {
  // === 唯一标识 ===
  id: string;                    // 全局唯一ID
  entityType: string;           // 实体类型：'message' | 'case' | 'consultation' | 'community' | 'profile'
  
  // === 内容信息 ===
  title: string;                // 标题
  content: string;              // 内容
  summary?: string;             // 摘要（自动生成或手动填写）
  
  // === 分类和标签 ===
  category?: MessageCategory;   // 消息分类（如为消息类型）
  subCategory?: string;         // 子分类
  tags: string[];               // 标签
  keywords: string[];           // 关键词
  
  // === 作者信息（文责自负） ===
  authorId: string;             // 作者用户ID
  authorName: string;           // 作者显示名称
  authorRole: AuthorRole;       // 作者角色
  authorCredentials?: string;   // 作者资质/职称
  institution?: string;         // 所属机构
  
  // === 时间信息（完整可追溯） ===
  createdAt: string;            // 创建时间 ISO 8601
  updatedAt?: string;           // 最后更新时间
  publishedAt?: string;         // 发布时间
  lastAccessedAt?: string;      // 最后访问时间（用于存储优化）
  
  // === 数据状态 ===
  status: DataStatus;           // 数据状态
  version: number;              // 版本号（用于追踪修改）
  
  // === 互动数据 ===
  viewCount: number;            // 查看次数
  likeCount: number;            // 点赞数
  commentCount: number;         // 评论数
  shareCount: number;           // 分享到微信次数
  saveCount: number;            // 收藏次数
  
  // === 质量指标 ===
  isFeatured: boolean;          // 是否精选（平台推荐）
  isVerified: boolean;          // 是否平台认证
  verificationNotes?: string;   // 认证备注
  
  // === 微信互通相关 ===
  sourceType?: 'original' | 'wechat' | 'import'; // 来源类型
  originalWeChatContent?: string;  // 原始微信内容（如有）
  wechatOptimizedContent?: string; // 优化后的微信分享内容
  
  // === 医疗特定字段 ===
  medicalField?: string;        // 医学领域（如：心血管、肿瘤）
  evidenceLevel?: 'A' | 'B' | 'C' | 'D'; // 证据等级 A:最高
  patientInfo?: string;         // 患者信息（匿名化后）
  treatmentOutcome?: string;    // 治疗结果
  
  // === 存储管理 ===
  storageTier: StorageTier;     // 当前存储层级
  estimatedValueScore: number;  // 预估价值分数（0-100）
  
  // === 关联关系 ===
  relatedPostIds: string[];     // 相关帖子ID
  parentPostId?: string;        // 父帖子ID（如为回复）
  
  // === 元数据 ===
  metadata: Record<string, any>; // 扩展元数据
}

/**
 * 消息帖子 - 专用于消息功能
 */
export interface MessagePost extends MedicalPost {
  entityType: 'message';
  category: MessageCategory;  // 消息必须有关联分类
  urgency?: 'high' | 'medium' | 'low'; // 紧急程度
  expirationDate?: string;    // 有效期（如公告）
}

/**
 * 医案帖子 - 专用于医案分享功能
 */
export interface MedicalCasePost extends MedicalPost {
  entityType: 'case';
  patientAge?: number;
  patientGender?: 'male' | 'female' | 'other';
  diagnosis?: string;
  treatmentPlan?: string;
  medications?: string[];
  outcome?: 'cured' | 'improved' | 'stable' | 'worsened';
  followUpPeriod?: string;
}

/**
 * 咨询帖子 - 专用于寻医问药功能
 */
export interface ConsultationPost extends MedicalPost {
  entityType: 'consultation';
  questionType: 'diagnosis' | 'treatment' | 'medication' | 'other';
  urgency: 'high' | 'medium' | 'low';
  hasImages?: boolean;
  doctorReplies?: string[]; // 医生回复ID列表
}

/**
 * 社区帖子 - 专用于专病社区功能
 */
export interface CommunityPost extends MedicalPost {
  entityType: 'community';
  diseaseCategory: string;    // 疾病分类
  discussionType: 'question' | 'experience' | 'support' | 'news';
  isSticky?: boolean;         // 是否置顶
}


// src/components/layout/DesktopLayout.tsx
import React from 'react';
import { Link, Outlet, useNavigate } from 'react-router-dom';
import { useAuth } from '../../contexts/AuthContext'; // 注意：现在直接从contexts导入
import { User } from 'lucide-react';
import Logo from '../Logo/Logo';

interface DesktopLayoutProps {
  children?: React.ReactNode;
}

export default function DesktopLayout({ children }: DesktopLayoutProps) {
  const navigate = useNavigate();
  const { user, logout } = useAuth();

  const handleLogout = () => {
    logout();
    navigate('/login');
  };

  return (
    <div className="desktop-layout min-h-screen bg-gray-50">
      <header className="bg-white shadow-sm px-6 py-4 sticky top-0 z-50">
        <div className="container mx-auto flex justify-between items-center">
          {/* Logo区域 - 只有一个标题结构！ */}
          <div 
            className="cursor-pointer flex items-center"
            onClick={() => navigate('/desktop/home')}
          >
            <Logo size="medium" />
            {/* 只保留这一套标题结构 */}
            <div className="ml-3">
              <div className="text-lg font-bold text-blue-600">众创医案平台</div>
              <div className="text-xs text-gray-500">共享医学智慧</div>
            </div>
          </div>
          
          {/* 主导航 - 五大功能 */}
          <nav className="flex items-center space-x-6">
            <Link 
              to="/desktop/cases" 
              className="text-gray-700 hover:text-blue-600 font-medium px-3 py-2"
            >
              医案分享
            </Link>
            <Link 
              to="/desktop/consult" 
              className="text-gray-700 hover:text-blue-600 font-medium px-3 py-2"
            >
              寻医问药
            </Link>
            <Link 
              to="/desktop/community" 
              className="text-gray-700 hover:text-blue-600 font-medium px-3 py-2"
            >
              专病社区
            </Link>
            <Link 
              to="/desktop/messages" 
              className="text-gray-700 hover:text-blue-600 font-medium px-3 py-2"
            >
              消息
            </Link>
            <Link 
              to="/desktop/profile" 
              className="text-gray-700 hover:text-blue-600 font-medium px-3 py-2"
            >
              我的
            </Link>
          </nav>
          
          {/* 用户操作区域 */}
          <div className="flex items-center space-x-4">
            {user ? (
              <>
                <div className="flex items-center space-x-2">
                  <div className="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center">
                    <User className="w-4 h-4 text-blue-600" />
                  </div>
                  <span className="text-sm text-gray-700">{user.username}</span>
                </div>
                <button
                  onClick={handleLogout}
                  className="px-3 py-1 text-sm text-gray-600 hover:bg-gray-100 rounded"
                >
                  退出
                </button>
              </>
            ) : (
              <>
                <button
                  onClick={() => navigate('/login')}
                  className="px-3 py-1 text-sm text-blue-600 hover:text-blue-800"
                >
                  登录
                </button>
                <button
                  onClick={() => navigate('/login?tab=register')}
                  className="px-3 py-1 text-sm bg-blue-600 text-white rounded hover:bg-blue-700"
                >
                  注册
                </button>
              </>
            )}
          </div>
        </div>
      </header>

      <main className="container mx-auto px-6 py-8">
        {children || <Outlet />}
      </main>
    </div>
  );
}
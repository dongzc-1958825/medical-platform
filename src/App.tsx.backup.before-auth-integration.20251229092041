// src/App.tsx
import { BrowserRouter, Routes, Route, Navigate } from 'react-router-dom';
import { isMobileDevice } from './shared/utils/device';

// Layouts
import DesktopLayout from './components/layout/DesktopLayout';
import MobileLayout from './components/layout/MobileLayout';

// 主页面文件（在 src/pages/ 根目录下）
import HomePage from './pages/HomePage';
import CasesPage from './pages/CasesPage';
import ConsultationPage from './pages/ConsultationPage';
import CommunityPage from './pages/CommunityPage';
import MessagesPage from './pages/MessagesPage';
import ProfilePage from './pages/ProfilePage';
import LoginPage from './pages/LoginPage'; // 新增导入

// 移动端专用页面（如果存在）
import MobileHomePage from './pages/mobile/MobileHomePage';
import MobileCasesPage from './pages/mobile/MobileCasesPage';
import MobileConsultPage from './pages/mobile/MobileConsultPage';
import MobileCommunityPage from './pages/mobile/MobileCommunityPage';
import MobileMessagesPage from './pages/mobile/MobileMessagesPage';
import MobileProfilePage from './pages/mobile/MobileProfilePage';

// 设备重定向组件
const DeviceRedirect = () => {
  const isMobile = isMobileDevice();
  return isMobile ? 
    <Navigate to="/mobile/home" replace /> : 
    <Navigate to="/desktop/home" replace />;
};

function App() {
  return (
    <BrowserRouter>
      <Routes>
        {/* 根路径重定向到设备对应页面 */}
        <Route path="/" element={<DeviceRedirect />} />

        {/* 登录页面 - 独立页面，不包含在布局中 */}
        <Route path="/login" element={<LoginPage />} />
        
        {/* 注册页面 - 如果需要，可以添加 */}
        {/* <Route path="/register" element={<RegisterPage />} /> */}

        {/* 桌面端路由 - 使用主页面文件 */}
        <Route path="/desktop" element={<DesktopLayout />}>
          <Route index element={<Navigate to="home" replace />} />
          <Route path="home" element={<HomePage />} />
          <Route path="cases" element={<CasesPage />} />
          <Route path="consult" element={<ConsultationPage />} />
          <Route path="community" element={<CommunityPage />} />
          <Route path="messages" element={<MessagesPage />} />
          <Route path="profile" element={<ProfilePage />} />
        </Route>

        {/* 移动端路由 - 使用移动端专用页面 */}
        <Route path="/mobile" element={<MobileLayout />}>
          <Route index element={<Navigate to="home" replace />} />
          <Route path="home" element={<MobileHomePage />} />
          <Route path="cases" element={<MobileCasesPage />} />
          <Route path="consult" element={<MobileConsultPage />} />
          <Route path="community" element={<MobileCommunityPage />} />
          <Route path="messages" element={<MobileMessagesPage />} />
          <Route path="profile" element={<MobileProfilePage />} />
        </Route>

        {/* 404 页面 */}
        <Route path="*" element={
          <div className="flex items-center justify-center h-screen">
            <div className="text-center">
              <h1 className="text-2xl font-bold mb-4">404 - 页面未找到</h1>
              <p className="mb-4">您访问的页面不存在</p>
              <a href="/" className="text-blue-600 hover:underline">
                返回首页
              </a>
            </div>
          </div>
        } />
      </Routes>
    </BrowserRouter>
  );
}

export default App;
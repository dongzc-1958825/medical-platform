// src/types/message.ts
// 消息类型定义 - 为 MessagesPage.tsx 提供支持

/**
 * 消息评论类型
 */
export interface MessageComment {
  id: string;
  author: string;
  content: string;
  time: string;
  likes: number;
  replies?: MessageComment[];
}

/**
 * 消息项类型
 */
export interface MessageItem {
  id: string;
  type: 'new_medicine' | 'professional_article' | 'announcement' | 'special_effect' | 'lesson_learned';
  title: string;
  content: string;
  author: string;
  publishTime: string;
  viewCount: number;
  likeCount: number;
  commentCount: number;
  tags?: string[];
  comments: MessageComment[];
  isPinned?: boolean;
}

/**
 * 消息分类类型（用于分类导航）
 */
export interface MessageCategory {
  id: string;
  name: string;
  icon: string;
  description: string;
  count: number;
}

// 同时导出共享类型（保持兼容性）
export * from '../shared/types/message';
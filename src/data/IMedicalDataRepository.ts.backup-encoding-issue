  return {
    databaseName: 'medical-data-db',
    databaseVersion: 1,
    objectStoreName: 'posts',
    keyPath: 'id',
    indexes: [
      { name: 'byEntityType', keyPath: 'entityType' },
      { name: 'byCategory', keyPath: 'category' },
      { name: 'byAuthor', keyPath: 'authorId' },
      { name: 'byCreatedAt', keyPath: 'createdAt' },
      { name: 'byStatus', keyPath: 'status' },
      { name: 'byStorageTier', keyPath: 'storageTier' }
    ],
    autoIncrement: false
  };
}

/**
 * 楠岃瘉甯栧瓙鏁版嵁
 */
export function validatePostData(data: CreatePostData): {
  isValid: boolean;
  errors: string[];
} {
  const errors: string[] = [];
  
  // 蹇呭～瀛楁妫€鏌?
  if (!data.title || data.title.trim().length === 0) {
    errors.push('鏍囬涓嶈兘涓虹┖');
  }
  
  if (!data.content || data.content.trim().length === 0) {
    errors.push('鍐呭涓嶈兘涓虹┖');
  }
  
  if (data.content.trim().length < 10) {
    errors.push('鍐呭鑷冲皯闇€瑕?0涓瓧绗?);
  }
  
  if (!data.authorId || !data.authorName || !data.authorRole) {
    errors.push('浣滆€呬俊鎭笉瀹屾暣');
  }
  
  if (!data.entityType) {
    errors.push('瀹炰綋绫诲瀷涓嶈兘涓虹┖');
  }
  
  // 娑堟伅绫诲瀷蹇呴』鏈夊叧鑱斿垎绫?
  if (data.entityType === 'message' && !data.category) {
    errors.push('娑堟伅绫诲瀷蹇呴』鎸囧畾鍒嗙被');
  }
  
  // 鏍囩鏁伴噺闄愬埗
  if (data.tags && data.tags.length > 10) {
    errors.push('鏍囩鏁伴噺涓嶈兘瓒呰繃10涓?);
  }
  
  return {
    isValid: errors.length === 0,
    errors
  };
}

/**
 * 鐢熸垚甯栧瓙ID
 */
export function generatePostId(): string {
  const timestamp = Date.now().toString(36);
  const random = Math.random().toString(36).substr(2, 9);
  return `post_${timestamp}_${random}`;
}

/**
 * 璁＄畻甯栧瓙棰勪及浠峰€煎垎鏁?
 */
export function calculateEstimatedValueScore(post: CreatePostData): number {
  let score = 50; // 鍩虹鍒嗘暟
  
  // 浣滆€呰祫璐ㄥ姞鍒?
  if (post.authorCredentials) score += 10;
  if (post.institution) score += 5;
  
  // 鍐呭璐ㄩ噺璇勪及
  const contentLength = post.content.length;
  if (contentLength > 500) score += 10;
  if (contentLength > 1000) score += 5;
  
  // 鍒嗙被閲嶈鎬?
  if (post.category === 'lesson-learned') score += 15; // 鍓嶈溅涔嬮壌鏈€閲嶈
  if (post.category === 'new-drug') score += 10; // 鏂拌嵂淇℃伅閲嶈
  
  // 鍖荤枟棰嗗煙涓撲笟鎬?
  if (post.medicalField) score += 5;
  if (post.evidenceLevel === 'A' || post.evidenceLevel === 'B') score += 10;
  
  return Math.min(score, 100);
}


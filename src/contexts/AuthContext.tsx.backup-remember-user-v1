// src/contexts/AuthContext.tsx
import React, { createContext, useContext, useState, useEffect, ReactNode } from "react";

export interface User {
  id: string;
  username: string;
  email: string;
  role: "patient" | "doctor" | "admin";
  avatar?: string;
  specialties?: string[];
}

export interface AuthContextType {
  user: User | null;
  isLoading: boolean;
  login: (email: string, password: string) => Promise<{ success: boolean; message?: string }>;
  logout: () => void;
  register: (userData: {
    username: string;
    email: string;
    password: string;
    role: "patient" | "doctor";
    specialties?: string[];
  }) => Promise<{ success: boolean; message?: string }>;
  updateProfile: (userData: Partial<User>) => void;
}

const AuthContext = createContext<AuthContextType | undefined>(undefined);

const MOCK_USERS = [
  {
    id: "1",
    username: "测试用户",
    email: "test@example.com",
    role: "patient" as const,
    avatar: "https://api.dicebear.com/7.x/avataaars/svg?seed=test"
  },
  {
    id: "2",
    username: "张医生",
    email: "doctor@example.com",
    role: "doctor" as const,
    specialties: ["内科", "中医"],
    avatar: "https://api.dicebear.com/7.x/avataaars/svg?seed=doctor"
  }
];

export const AuthProvider: React.FC<{ children: ReactNode }> = ({ children }) => {
  const [user, setUser] = useState<User | null>(null);
  const [isLoading, setIsLoading] = useState(true);

  useEffect(() => {
    const loadUser = async () => {
      try {
        const savedUser = localStorage.getItem("medical-platform-user");
        if (savedUser) {
          const parsedUser = JSON.parse(savedUser);
          setUser(parsedUser);
        }
      } catch (error) {
        console.error("加载用户信息失败:", error);
        localStorage.removeItem("medical-platform-user");
      } finally {
        setIsLoading(false);
      }
    };

    loadUser();
  }, []);

  const login = async (email: string, password: string) => {
    setIsLoading(true);
    try {
      await new Promise(resolve => setTimeout(resolve, 500));

      console.log("AuthContext.login - 尝试登录:", email);

      // 1. 首先检查localStorage中注册的用户
      const savedUser = localStorage.getItem("medical-platform-user");
      if (savedUser) {
        try {
          const parsedUser = JSON.parse(savedUser);
          if (parsedUser.email === email) {
            console.log("找到匹配的注册用户");
            if (password && password.trim() !== "") {
              console.log("密码验证通过");
              setUser(parsedUser);
              localStorage.setItem("medical-platform-user", JSON.stringify(parsedUser));
              return { success: true };
            }
          }
        } catch (parseError) {
          console.error("解析localStorage失败:", parseError);
        }
      }

      // 2. 检查MOCK_USERS
      const foundUser = MOCK_USERS.find(u => u.email === email);
      if (foundUser) {
        if (password === "123456") {
          setUser(foundUser);
          localStorage.setItem("medical-platform-user", JSON.stringify(foundUser));
          return { success: true };
        }
      }

      return { success: false, message: "邮箱或密码错误" };
    } catch (error) {
      return { success: false, message: "登录失败，请检查网络连接" };
    } finally {
      setIsLoading(false);
    }
  };

  const logout = () => {
    setUser(null);
    localStorage.removeItem("medical-platform-user");
  };

  const register = async (userData: {
    username: string;
    email: string;
    password: string;
    role: "patient" | "doctor";
    specialties?: string[];
  }) => {
    setIsLoading(true);
    try {
      console.log("🚀 === REGISTER FUNCTION START ===");
      console.log("📧 注册邮箱:", userData.email);
      console.log("👤 用户名:", userData.username);
      
      await new Promise(resolve => setTimeout(resolve, 500));

      // 1. 检查MOCK_USERS
      console.log("🔍 检查MOCK_USERS...");
      const emailExists = MOCK_USERS.some(u => u.email === userData.email);
      if (emailExists) {
        console.log("❌ 邮箱被MOCK_USERS占用");
        return { success: false, message: "该邮箱已被注册" };
      }
      console.log("✅ MOCK_USERS检查通过");

      // 2. 检查localStorage
      console.log("📦 检查localStorage...");
      const savedUser = localStorage.getItem("medical-platform-user");
      console.log("   localStorage内容:", savedUser);
      
      if (savedUser) {
        try {
          const parsedUser = JSON.parse(savedUser);
          console.log("   ✅ 解析成功，用户邮箱:", parsedUser.email);
          if (parsedUser.email === userData.email) {
            console.log("❌ 邮箱已被注册");
            return { success: false, message: "该邮箱已被注册" };
          }
        } catch (e) {
          console.log("⚠️ 解析失败，但继续注册:", e.message);
        }
      } else {
        console.log("   ℹ️ localStorage为空");
      }

      // 3. 创建新用户
      console.log("👤 创建新用户对象...");
      const newUser: User = {
        id: "user-" + Date.now(),
        username: userData.username,
        email: userData.email,
        role: userData.role,
        specialties: userData.specialties || [],
        avatar: `https://api.dicebear.com/7.x/avataaars/svg?seed=${userData.email}`
      };
      
      console.log("✅ 用户对象创建成功:", newUser);

      // 4. 保存到React状态
      console.log("⚛️ 调用setUser()保存到React状态...");
      setUser(newUser);
      console.log("✅ setUser()调用完成");

      // 5. 保存到localStorage
      console.log("💾 保存到localStorage...");
      const userJson = JSON.stringify(newUser);
      console.log("   JSON数据:", userJson);
      
      localStorage.setItem("medical-platform-user", userJson);
      console.log("✅ localStorage.setItem()调用完成");

      // 6. 立即验证保存
      console.log("🔍 验证保存结果...");
      const verify = localStorage.getItem("medical-platform-user");
      console.log("   读取结果:", verify);
      
      if (verify) {
        console.log("✅ 验证成功！用户数据已保存");
        try {
          const parsedVerify = JSON.parse(verify);
          console.log("   验证邮箱:", parsedVerify.email);
          console.log("   ✅ 邮箱匹配:", parsedVerify.email === userData.email);
        } catch(e) {
          console.log("⚠️ 验证数据解析失败:", e.message);
        }
      } else {
        console.error("❌ 验证失败！localStorage为空");
        throw new Error("localStorage保存失败");
      }

      console.log("🎉 === REGISTER FUNCTION SUCCESS ===");
      return { success: true };
      
    } catch (error) {
      console.error("💥 REGISTER ERROR:", error);
      return { 
        success: false, 
        message: error instanceof Error ? error.message : "注册失败，请稍后重试"
      };
    } finally {
      setIsLoading(false);
    }
  };

  const updateProfile = (userData: Partial<User>) => {
    if (user) {
      const updatedUser = { ...user, ...userData };
      setUser(updatedUser);
      localStorage.setItem("medical-platform-user", JSON.stringify(updatedUser));
    }
  };

  const value: AuthContextType = {
    user,
    isLoading,
    login,
    logout,
    register,
    updateProfile
  };

  return (
    <AuthContext.Provider value={value}>
      {children}
    </AuthContext.Provider>
  );
};

export const useAuth = (): AuthContextType => {
  const context = useContext(AuthContext);
  if (context === undefined) {
    throw new Error("useAuth必须在AuthProvider内部使用");
  }
  return context;
};

// 关键修复：导出AuthContext变量，供shared/hooks/useAuth.ts使用
export { AuthContext };
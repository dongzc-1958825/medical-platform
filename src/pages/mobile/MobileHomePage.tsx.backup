import React from 'react';
import { useNavigate, NavLink } from 'react-router-dom';
import { useAuth } from '../../shared/hooks/useAuth';
import { 
  FileText,          // 医案分享
  Stethoscope,       // 寻医问药
  Users,             // 专病社区
  MessageCircle,     // 消息中心
  Bell,              // 通知
  Calendar,          // 日历/日程
  TrendingUp,        // 趋势/统计
  BookOpen,          // 学习
  Shield,            // 安全/隐私
  Heart,             // 健康
  Star,              // 收藏/推荐

    {
      title: "待办事项",
      icon: <Bell className="w-5 h-5" />,
      count: 5,
      color: "bg-red-50 text-red-700"
    },
    {
      title: "收藏医案",
      icon: <Star className="w-5 h-5" />,
      count: 12,
      color: "bg-yellow-50 text-yellow-700"
    }
  ];

  // 推荐内容
  const recommendations = [
    {
      title: "心血管疾病最新诊疗指南",
      category: "心内科",
      readTime: "10分钟"
    },
    {
      title: "糖尿病管理实用技巧",
      category: "内分泌科",
      readTime: "8分钟"
    },
    {
      title: "呼吸系统感染病例讨论",
      category: "呼吸科",
      readTime: "15分钟"
    }
  ];


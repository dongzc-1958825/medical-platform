        {/* Logo区域 */}
        <div className="flex flex-col items-center justify-center py-12">
          <div className="w-24 h-24 bg-blue-100 rounded-full flex items-center justify-center mb-6">
            <span className="text-3xl font-bold text-blue-600">医</span>
          </div>
          <h1 className="text-3xl font-bold text-gray-900 mb-2">众创医案</h1>
          <p className="text-gray-600 text-center mb-8">
            医学专业人士的协作平台
            <br />
            分享案例，共同成长
          </p>
        </div>

        {/* 功能介绍 */}
        <div className="space-y-4 mb-12">
          <div className="bg-white rounded-xl p-4 shadow-sm border">
            <div className="flex items-center mb-3">
              <div className="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center mr-3">
                <FileText className="w-5 h-5 text-blue-600" />
              </div>
              <div>
                <h3 className="font-semibold text-gray-900">医案分享</h3>
                <p className="text-sm text-gray-500">浏览和分享真实医学案例</p>
              </div>
            </div>
          </div>

          <div className="bg-white rounded-xl p-4 shadow-sm border">
            <div className="flex items-center mb-3">
              <div className="w-10 h-10 bg-green-100 rounded-lg flex items-center justify-center mr-3">
                <Stethoscope className="w-5 h-5 text-green-600" />
              </div>
              <div>
                <h3 className="font-semibold text-gray-900">寻医问药</h3>
                <p className="text-sm text-gray-500">向专业医生咨询建议</p>
              </div>
            </div>
          </div>

          <div className="bg-white rounded-xl p-4 shadow-sm border">
            <div className="flex items-center mb-3">
              <div className="w-10 h-10 bg-purple-100 rounded-lg flex items-center justify-center mr-3">
                <Users className="w-5 h-5 text-purple-600" />
              </div>
              <div>
                <h3 className="font-semibold text-gray-900">专病社区</h3>
                <p className="text-sm text-gray-500">参与专业疾病讨论</p>
              </div>
            </div>
          </div>
        </div>


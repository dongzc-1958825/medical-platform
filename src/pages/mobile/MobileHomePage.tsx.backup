      {/* 统计数据 */}
      <div className="bg-gradient-to-r from-gray-50 to-white border border-gray-200 rounded-xl p-4">
        <div className="flex items-center justify-between mb-3">
          <h3 className="font-semibold text-gray-900">本周数据</h3>
          <TrendingUp className="w-5 h-5 text-green-500" />
        </div>
        <div className="grid grid-cols-2 gap-4">
          <div className="text-center">
            <p className="text-2xl font-bold text-blue-600">42</p>
            <p className="text-sm text-gray-600">医案浏览</p>
          </div>
          <div className="text-center">
            <p className="text-2xl font-bold text-green-600">8</p>
            <p className="text-sm text-gray-600">参与讨论</p>
          </div>
        </div>
      </div>

      {/* 底部安全提示 */}
      <div className="text-center pt-4 pb-8 border-t border-gray-100">
        <div className="flex items-center justify-center text-gray-500 text-sm mb-2">
          <Shield className="w-4 h-4 mr-1" />
          平台已通过医疗信息安全认证
        </div>
        <p className="text-xs text-gray-400">
          患者隐私保护是我们的首要责任
        </p>
      </div>

        </div>
      </div>

      {/* 推荐阅读 */}
      <div>
        <div className="flex justify-between items-center mb-4">
          <h2 className="text-lg font-bold text-gray-900">推荐阅读</h2>
          <button className="text-sm text-gray-500 flex items-center">
